<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Listing</title>
</head>
<body>

    <h1>Listion of all Hotels</h1>


    <ul>
   <%  listings.forEach(listing=>{ %>

        <li> 
          <a href="/listings/<%=listing._id %>"><%=listing.title  %></a>
          
        </li>
      
  <%    })%>
</ul>
    
    
</body>
</html>