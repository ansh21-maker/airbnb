

<%layout("/layout/boilerplate") %>

<body>

    <h3>Listion of all Hotels</h3>
    <div class=" row row-cols-lg-4 row-cols-md-2 row-cols-sm-1 g-3">
   <%  listings.forEach(listing=>{ %>
    <a href="/listings/<%=listing._id %>" class="listing-link">
  <div class="card col" >
    
  <img src="<%=listing.image.url %>" class="card-img-top" alt="...">
    <div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-text">
    <%=listing.title%> <br>
    &#x20B9; <%=listing.price.toLocaleString("en-IN")%>/night
</p>   
  </div>
</div>
    <%})%>
    </div>
    </a>
</body>
